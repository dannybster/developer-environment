{
  "alwaysThinkingEnabled": true,
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",
      "Agent",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git tag *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm ls *)",
      "Bash(npx eslint *)",
      "Bash(npx jest *)",
      "Bash(npx tsc *)",
      "Bash(npx lint-staged *)",
      "Bash(gh issue view *)",
      "Bash(gh issue create *)",
      "Bash(gh issue comment *)",
      "Bash(gh issue edit *)",
      "Bash(gh issue list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr create *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr review *)",
      "Bash(gh pr list *)",
      "Bash(gh api *)",
      "Bash(gh run view *)",
      "Bash(gh repo view *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cat *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push --force)",
      "Bash(npm publish *)",
      "Bash(gh repo delete *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git push *)",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protect-main.sh"
          }
        ]
      }
    ]
  }
}
